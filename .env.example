# Firebase (client — prefixed with VITE_ for Vite)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Vercel serverless function env vars (set in Vercel dashboard) ---

# Firebase Admin (from service account JSON)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# OpenAI
OPENAI_API_KEY=sk-...

# Azure Foundry — PersonalAssistant
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
FOUNDRY_AGENT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your_project/applications/PersonalAssistant/protocols/openai/responses?api-version=2025-11-15-preview

# Azure Foundry — ResumeAgent
RESUME_AGENT_TENANT_ID=your_tenant_id
RESUME_AGENT_CLIENT_ID=your_client_id
RESUME_AGENT_CLIENT_SECRET=your_client_secret
RESUME_AGENT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your_project/applications/ResumeAgent/protocols/openai/responses?api-version=2025-11-15-preview

# VM API
VM_API=http://your-vm-ip:5000

# JobSpy (optional)
# JOBSPY_API_URL=http://your-jobspy-api:8000
